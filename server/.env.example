# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/jtcutz

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CLIENT_URL=https://jtcutz-client.vercel.app/

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL="JT CUTZ <onboarding@resend.dev>" # Change this to your custom sender address once you verify your domain in Resend

# Admin
ADMIN_EMAIL=admin@jtcutz.com

# Environment
NODE_ENV=development
